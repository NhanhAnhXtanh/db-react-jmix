<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1" author="db-react-jmix">
        <createTable tableName="META_CONNECTION_CONFIG">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_META_CONNECTION_CONFIG"/>
            </column>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="CODE" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="DATABASE_TYPE" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="HOST" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="PORT" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="DB_NAME" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="USERNAME" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="PASSWORD" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="SCHEMA_NAME" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="2" author="db-react-jmix">
        <createTable tableName="META_PACK">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_META_PACK"/>
            </column>
            <column name="CODE" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="DESCRIPTION" type="VARCHAR(255)"/>
            <column name="CURRENT_VERSION_NO" type="INT"/>
            <column name="CURRENT_HASH_DATA" type="CLOB"/>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
            <column name="LAST_MODIFIED_BY" type="VARCHAR(255)"/>
            <column name="LAST_MODIFIED_DATE" type="${offsetDateTime.type}"/>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="${offsetDateTime.type}"/>
        </createTable>
    </changeSet>
    <changeSet id="3" author="db-react-jmix">
        <createTable tableName="META_PACK_VERSION">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_META_PACK_VERSION"/>
            </column>
            <column name="META_PACK_ID" type="UUID"/>
            <column name="VERSION_NO" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="FIELD_DATA" type="CLOB"/>
            <column name="HASH_DATA" type="CLOB"/>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
            <column name="LAST_MODIFIED_BY" type="VARCHAR(255)"/>
            <column name="LAST_MODIFIED_DATE" type="${offsetDateTime.type}"/>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="${offsetDateTime.type}"/>
        </createTable>
    </changeSet>
    <changeSet id="4" author="db-react-jmix">
        <createTable tableName="META_SET">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_META_SET"/>
            </column>
            <column name="CODE" type="VARCHAR(255)"/>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="DESCRIPTION" type="VARCHAR(255)"/>
            <column name="CURRENT_VERSION_NO" type="INT"/>
            <column name="CURRENT_HASH_DATA" type="CLOB"/>
            <column name="STATUS" type="VARCHAR(255)"/>
            <column name="OPERATION" type="VARCHAR(255)"/>
            <column name="META_PACK_ID" type="UUID"/>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
            <column name="LAST_MODIFIED_BY" type="VARCHAR(255)"/>
            <column name="LAST_MODIFIED_DATE" type="${offsetDateTime.type}"/>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="${offsetDateTime.type}"/>
        </createTable>
    </changeSet>
    <changeSet id="5" author="db-react-jmix">
        <createTable tableName="META_SET_VERSION">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_META_SET_VERSION"/>
            </column>
            <column name="FIELD_DATA" type="CLOB"/>
            <column name="META_SET_ID" type="UUID"/>
            <column name="HASH_DATA" type="CLOB"/>
            <column name="VERSION_NO" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
            <column name="LAST_MODIFIED_BY" type="VARCHAR(255)"/>
            <column name="LAST_MODIFIED_DATE" type="${offsetDateTime.type}"/>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="${offsetDateTime.type}"/>
        </createTable>
    </changeSet>
    <changeSet id="6" author="db-react-jmix">
        <createTable tableName="META_SYNC">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_META_SYNC"/>
            </column>
            <column name="META_SET_ID" type="UUID"/>
            <column name="CONNECTION_CONFIG_ID" type="UUID"/>
            <column name="FIELD_DATA" type="CLOB"/>
            <column name="HASH_DATA" type="CLOB"/>
            <column name="SYNC_VERSION_NO" type="INT"/>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="${offsetDateTime.type}"/>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
            <column name="LAST_MODIFIED_BY" type="VARCHAR(255)"/>
            <column name="LAST_MODIFIED_DATE" type="${offsetDateTime.type}"/>
        </createTable>
    </changeSet>
    <changeSet id="7" author="db-react-jmix">
        <createTable tableName="MONGO_SCHEMA_SNAPSHOT">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_MONGO_SCHEMA_SNAPSHOT"/>
            </column>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="CONNECTION_KEY" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="STATUS" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="SCHEMA_HASH" type="VARCHAR(64)"/>
            <column name="SCHEMA_JSON" type="CLOB"/>
            <column name="CHECKPOINT_JSON" type="CLOB"/>
            <column name="RESUME_TOKEN_JSON" type="CLOB"/>
            <column name="SCANNED_DOCS" type="BIGINT"/>
            <column name="TOTAL_COLLECTIONS" type="INT"/>
            <column name="PROCESSED_COLLECTIONS" type="INT"/>
            <column name="CURRENT_COLLECTION" type="VARCHAR(255)"/>
            <column name="ERROR_MESSAGE" type="VARCHAR(2000)"/>
            <column name="STARTED_AT" type="${offsetDateTime.type}"/>
            <column name="COMPLETED_AT" type="${offsetDateTime.type}"/>
        </createTable>
    </changeSet>
    <changeSet id="8" author="db-react-jmix">
        <createIndex indexName="IDX_META_CONNECTION_CONFIG_CODE" tableName="META_CONNECTION_CONFIG" unique="true">
            <column name="CODE"/>
        </createIndex>
    </changeSet>
    <changeSet id="9" author="db-react-jmix" dbms="postgresql">
        <createIndex indexName="IDX_META_PACK_CODE" tableName="META_PACK" unique="true">
            <column name="CODE"/>
        </createIndex>

        <modifySql>
            <append value="where DELETED_DATE is null"/>
        </modifySql>
    </changeSet>
    <changeSet id="10" author="db-react-jmix">
        <createIndex indexName="IDX_META_PACK_VERSION_PACK" tableName="META_PACK_VERSION">
            <column name="META_PACK_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="META_PACK_ID" baseTableName="META_PACK_VERSION"
                                 constraintName="FK_META_PACK_VERSION_ON_META_PACK" referencedColumnNames="ID"
                                 referencedTableName="META_PACK"/>
    </changeSet>
    <changeSet id="11" author="db-react-jmix" dbms="postgresql">
        <createIndex indexName="IDX_META_PACK_VERSION_UNIQUE" tableName="META_PACK_VERSION" unique="true">
            <column name="META_PACK_ID"/>
            <column name="VERSION_NO"/>
        </createIndex>

        <modifySql>
            <append value="where DELETED_DATE is null"/>
        </modifySql>
    </changeSet>
    <changeSet id="12" author="db-react-jmix" dbms="postgresql">
        <createIndex indexName="IDX_META_SET_CODE" tableName="META_SET" unique="true">
            <column name="CODE"/>
        </createIndex>

        <modifySql>
            <append value="where DELETED_DATE is null"/>
        </modifySql>
    </changeSet>
    <changeSet id="13" author="db-react-jmix">
        <createIndex indexName="IDX_META_SET_VERSION_META_SET" tableName="META_SET_VERSION">
            <column name="META_SET_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="META_SET_ID" baseTableName="META_SET_VERSION"
                                 constraintName="FK_META_SET_VERSION_ON_META_SET" referencedColumnNames="ID"
                                 referencedTableName="META_SET"/>
    </changeSet>
    <changeSet id="14" author="db-react-jmix" dbms="postgresql">
        <createIndex indexName="IDX_META_SET_VERSION_META_SET_VERSION_NO" tableName="META_SET_VERSION" unique="true">
            <column name="META_SET_ID"/>
            <column name="VERSION_NO"/>
        </createIndex>

        <modifySql>
            <append value="where DELETED_DATE is null"/>
        </modifySql>
    </changeSet>
    <changeSet id="15" author="db-react-jmix">
        <createIndex indexName="IDX_MONGO_SCHEMA_SNAPSHOT_KEY" tableName="MONGO_SCHEMA_SNAPSHOT" unique="true">
            <column name="CONNECTION_KEY"/>
        </createIndex>
    </changeSet>
    <changeSet id="16" author="db-react-jmix">
        <addForeignKeyConstraint baseColumnNames="META_PACK_ID" baseTableName="META_SET"
                                 constraintName="FK_META_SET_ON_META_PACK" referencedColumnNames="ID"
                                 referencedTableName="META_PACK"/>
    </changeSet>
    <changeSet id="17" author="db-react-jmix">
        <addForeignKeyConstraint baseColumnNames="CONNECTION_CONFIG_ID" baseTableName="META_SYNC"
                                 constraintName="FK_META_SYNC_ON_CONNECTION_CONFIG" referencedColumnNames="ID"
                                 referencedTableName="META_CONNECTION_CONFIG"/>
    </changeSet>
    <changeSet id="18" author="db-react-jmix">
        <addForeignKeyConstraint baseColumnNames="META_SET_ID" baseTableName="META_SYNC"
                                 constraintName="FK_META_SYNC_ON_META_SET" referencedColumnNames="ID"
                                 referencedTableName="META_SET"/>
    </changeSet>
    <changeSet id="19" author="db-react-jmix">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="META_SYNC" columnName="IS_DELETED"/></not>
        </preConditions>
        <addColumn tableName="META_SYNC">
            <column name="IS_DELETED" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="20" author="db-react-jmix">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="META_SYNC_COMMIT"/></not>
        </preConditions>
        <createTable tableName="META_SYNC_COMMIT">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_META_SYNC_COMMIT"/>
            </column>
            <column name="PACK_CODE" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="VERSION_NO" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="COMMIT_MESSAGE" type="CLOB">
                <constraints nullable="false"/>
            </column>
            <column name="DIFF_JSON" type="CLOB"/>
            <column name="SUMMARY_JSON" type="CLOB"/>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="${offsetDateTime.type}"/>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
            <column name="LAST_MODIFIED_BY" type="VARCHAR(255)"/>
            <column name="LAST_MODIFIED_DATE" type="${offsetDateTime.type}"/>
        </createTable>
    </changeSet>
    <changeSet id="21" author="db-react-jmix">
        <preConditions onFail="MARK_RAN">
            <not><indexExists indexName="IDX_META_SYNC_COMMIT_PACK"/></not>
        </preConditions>
        <createIndex indexName="IDX_META_SYNC_COMMIT_PACK" tableName="META_SYNC_COMMIT">
            <column name="PACK_CODE"/>
        </createIndex>
    </changeSet>
    <changeSet id="22" author="db-react-jmix">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="META_SET" columnName="STATUS"/></not>
        </preConditions>
        <addColumn tableName="META_SET">
            <column name="STATUS" type="VARCHAR(50)"/>
            <column name="OPERATION" type="VARCHAR(500)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>