<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="metapack-1" author="db-react-jmix">
        <createTable tableName="META_PACK">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_META_PACK"/>
            </column>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="CODE" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(255)"/>
            <column name="DESCRIPTION" type="CLOB"/>
            <column name="CURRENT_VERSION_NO" type="INT"/>
            <column name="CURRENT_HASH_DATA" type="CLOB"/>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
            <column name="LAST_MODIFIED_BY" type="VARCHAR(255)"/>
            <column name="LAST_MODIFIED_DATE" type="${offsetDateTime.type}"/>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="${offsetDateTime.type}"/>
        </createTable>
        <createIndex indexName="IDX_META_PACK_CODE" tableName="META_PACK" unique="true">
            <column name="CODE"/>
        </createIndex>
    </changeSet>

    <changeSet id="metapack-2" author="db-react-jmix">
        <createTable tableName="META_PACK_VERSION">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_META_PACK_VERSION"/>
            </column>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="META_PACK_ID" type="UUID"/>
            <column name="VERSION_NO" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="FIELD_DATA" type="CLOB"/>
            <column name="HASH_DATA" type="CLOB"/>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
            <column name="LAST_MODIFIED_BY" type="VARCHAR(255)"/>
            <column name="LAST_MODIFIED_DATE" type="${offsetDateTime.type}"/>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="${offsetDateTime.type}"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="META_PACK_VERSION"
                                 baseColumnNames="META_PACK_ID"
                                 constraintName="FK_META_PACK_VERSION_PACK"
                                 referencedTableName="META_PACK"
                                 referencedColumnNames="ID"/>
        <createIndex indexName="IDX_META_PACK_VERSION_PACK" tableName="META_PACK_VERSION">
            <column name="META_PACK_ID"/>
        </createIndex>
        <createIndex indexName="IDX_META_PACK_VERSION_UNIQUE" tableName="META_PACK_VERSION" unique="true">
            <column name="META_PACK_ID"/>
            <column name="VERSION_NO"/>
        </createIndex>
    </changeSet>

    <changeSet id="metapack-3" author="db-react-jmix">
        <addColumn tableName="META_SET">
            <column name="META_PACK_ID" type="UUID"/>
        </addColumn>
        <addForeignKeyConstraint baseTableName="META_SET"
                                 baseColumnNames="META_PACK_ID"
                                 constraintName="FK_META_SET_PACK"
                                 referencedTableName="META_PACK"
                                 referencedColumnNames="ID"/>
    </changeSet>

</databaseChangeLog>
