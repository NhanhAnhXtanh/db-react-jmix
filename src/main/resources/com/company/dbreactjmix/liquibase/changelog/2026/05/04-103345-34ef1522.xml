<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1" author="db-react-jmix">
        <createTable tableName="META_SYNC_COMMIT">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_META_SYNC_COMMIT"/>
            </column>
            <column name="PACK_CODE" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="VERSION_NO" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="COMMIT_MESSAGE" type="CLOB">
                <constraints nullable="false"/>
            </column>
            <column name="DIFF_JSON" type="CLOB"/>
            <column name="SUMMARY_JSON" type="CLOB"/>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="DELETED_BY" type="VARCHAR(255)"/>
            <column name="DELETED_DATE" type="${offsetDateTime.type}"/>
            <column name="CREATED_BY" type="VARCHAR(255)"/>
            <column name="CREATED_DATE" type="${offsetDateTime.type}"/>
            <column name="LAST_MODIFIED_BY" type="VARCHAR(255)"/>
            <column name="LAST_MODIFIED_DATE" type="${offsetDateTime.type}"/>
        </createTable>
    </changeSet>
    <changeSet id="2" author="db-react-jmix">
        <addColumn tableName="META_SYNC">
            <column name="IS_DELETED" type="BOOLEAN"/>
        </addColumn>

        <addNotNullConstraint columnName="IS_DELETED" defaultNullValue="false" tableName="META_SYNC"/>
    </changeSet>
    <changeSet id="3" author="db-react-jmix">
        <createIndex indexName="IDX_META_SYNC_COMMIT_PACK" tableName="META_SYNC_COMMIT">
            <column name="PACK_CODE"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>