<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="meta-sync-add-connection-config-id" author="db-react-jmix">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="META_SYNC"/>
            <not><columnExists tableName="META_SYNC" columnName="CONNECTION_CONFIG_ID"/></not>
        </preConditions>
        <addColumn tableName="META_SYNC">
            <column name="CONNECTION_CONFIG_ID" type="UUID"/>
        </addColumn>
    </changeSet>

    <changeSet id="meta-sync-fk-connection-config" author="db-react-jmix">
        <preConditions onFail="MARK_RAN">
            <not><foreignKeyConstraintExists foreignKeyName="FK_META_SYNC_ON_CONNECTION_CONFIG"/></not>
        </preConditions>
        <addForeignKeyConstraint
                baseTableName="META_SYNC"
                baseColumnNames="CONNECTION_CONFIG_ID"
                constraintName="FK_META_SYNC_ON_CONNECTION_CONFIG"
                referencedTableName="META_CONNECTION_CONFIG"
                referencedColumnNames="ID"/>
    </changeSet>

</databaseChangeLog>
