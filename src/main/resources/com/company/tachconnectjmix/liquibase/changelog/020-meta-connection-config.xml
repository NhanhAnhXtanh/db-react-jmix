<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="tach-connect-jmix" context="!cuba">
        <createTable tableName="META_CONNECTION_CONFIG">
            <column name="ID" type="${uuid.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="VERSION" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="CODE" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="DATABASE_TYPE" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="HOST" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="PORT" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="DB_NAME" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="USERNAME" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="PASSWORD" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="SCHEMA_NAME" type="varchar(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="2" author="tach-connect-jmix" context="!cuba">
        <createIndex indexName="IDX_META_CONNECTION_CONFIG_CODE"
                     tableName="META_CONNECTION_CONFIG" unique="true">
            <column name="CODE"/>
        </createIndex>
    </changeSet>

